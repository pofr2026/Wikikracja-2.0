# Core
DEBUG=True
DEBUG_TOOLBAR=True

# Logging destination: 'console' (default) or 'file'
LOGGING_DESTINATION=console
# Log verbosity: CRITICAL, ERROR, WARNING, INFO, DEBUG, NOTSET
LOG_LEVEL=DEBUG
# Log file path (only used when LOGGING_DESTINATION=file)
LOG_FILE=/var/log/wiki.log

# Optional: Complete LOGGING dictionary override as JSON string
# LOGGING_JSON='{"version":1,"disable_existing_loggers":false,"formatters":{"verbose":{"format":"%(asctime)s %(levelname)s %(name)s %(message)s","datefmt":"%H:%M:%S"}},"handlers":{"console":{"class":"logging.StreamHandler","level":"DEBUG","formatter":"verbose","stream":"ext://sys.stdout"},"file":{"class":"logging.FileHandler","level":"DEBUG","filename":"log.log","formatter":"verbose"}},"loggers":{"":{"handlers":["console"],"level":"ERROR"},"django":{"handlers":["console"],"level":"ERROR"},"django.channels.server":{"handlers":["console"],"level":"ERROR"},"django.db.backends":{"handlers":["console","file"],"level":"ERROR"},"glosowania":{"handlers":["console"],"level":"ERROR"},"obywatele":{"handlers":["console"],"level":"ERROR"}}}'

SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
TIME_ZONE=Europe/Warsaw
LANGUAGE_CODE=pl

# Sessions / Remember me
# True: Django sets a session cookie without an expiration date (session cookie). The browser deletes it on close, so the user will be logged out after closing the browser/window, regardless of SESSION_COOKIE_AGE and "remember me."
# False: The session cookie is assigned an expiration date based on SESSION_COOKIE_AGE (e.g., 86400s = 1 day). The session expires after this time or upon logging out.
SESSION_EXPIRE_AT_BROWSER_CLOSE=False
# The number of seconds the standard session (cookie sessionid) remains valid. After this time, the user will be logged out if there is no "remember me" mechanism:
SESSION_COOKIE_AGE=86400
# Number of days for the "remember me" mode to be active. Used to calculate the longer validity of the token/cookie when the user selects "remember me":
REMEMBER_ME_DAYS=90

# Site configuration (used for email URLs and absolute URLs)
SITE_DOMAIN=127.0.0.1:8000
SITE_NAME="My Wikikracja"
SITE_NAME_MAX_12_CHARS="MyWikikracja" # For PWA
SITE_DESCRIPTION="My Wikikracja"

# Channels / Redis
# Use 'redis' hostname when running with docker-compose (service name)
# Use '127.0.0.1' when running Django locally without Docker
REDIS_HOST=redis://127.0.0.1:6379/1 # dev
# REDIS_HOST=redis://redis:6379/1 # docker

# Email (dev defaults to console backend; set SMTP settings for prod)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
SERVER_EMAIL=
DEFAULT_FROM_EMAIL=
EMAIL_SEND_DELAY_SECONDS=2

# Instance-specific voting parameters
WYMAGANYCH_PODPISOW=2
CZAS_NA_ZEBRANIE_PODPISOW=365
DYSKUSJA=3
CZAS_TRWANIA_REFERENDUM=3

# Chat settings
ARCHIVE_PUBLIC_CHAT_ROOM=9
DELETE_PUBLIC_CHAT_ROOM=360
# Max chat message length (chars), normal and embedded chat.
# (Argument-under-a-vote length is fixed by the Argument.content model field, not env.)
MESSAGE_MAX_LENGTH=2000

# Upload settings
UPLOAD_IMAGE_MAX_SIZE_MB=5
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760

# Citizens settings
ACCEPTANCE=3
DELETE_INACTIVE_USER_AFTER=30

# Group settings
GROUP_IS_PUBLIC=True

# Skip password check
# DEBUG_SKIP_AUTH=False

# Scheduler lock file location
SCHEDULER_LOCK_FILE="/tmp/wikikracja_scheduler.lock"

# Push Notifications (django-push-notifications):
# Email, required for all platforms:
VAPID_ADMIN_EMAIL=admin@example.com

# WebPush (Browser notifications - Chrome/Firefox/Edge)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# FCM (Android notifications)
FIREBASE_CERT_PATH=project-id-c3d86-firebase-adminsdk-fbsvc-98006966c4.json

# Notify users about your weekly meetings
MEETING_NOTIFICATION_CRON="50 19 * * 3"
